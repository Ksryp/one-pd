# SNK MES Frontend — environment variables
# Copy to .env.development for local dev, or set in Cloudflare Pages dashboard for production.
#
# Dev  → VITE_API_BASE_URL=http://localhost:8000
#         (Vite proxy also handles /api/* and /ws/*)
# Prod → VITE_API_BASE_URL=https://your-cloudflare-tunnel.example.com
#         (set in Cloudflare Pages project → Settings → Environment variables)

VITE_API_BASE_URL=http://localhost:8000
