# SNK MES Frontend — environment variables
# Copy to .env.local for local dev, or set in Cloudflare Pages dashboard

# API base URL:
#   - Dev (Vite proxy): leave empty
#   - Production: set to your cloudflared Quick Tunnel URL
#     e.g. https://random-name.trycloudflare.com
VITE_API_BASE_URL=

# Set to 'true' to fetch from FastAPI backend (requires running server)
# Set to 'false' or omit to use mock data
VITE_USE_API=false
