# SNK MES FastAPI Backend — environment variables
# Copy to .env and fill in actual values (never commit .env)

# PostgreSQL — production/quality/app data
PG_HOST=localhost
PG_PORT=5433
PG_NAME=snk_mes
PG_USER=admincptd
PG_PASS=your_pg_password_here

# TimescaleDB — machine data (MQTT pipeline, read-only from API)
TSDB_HOST=localhost
TSDB_PORT=5432
TSDB_NAME=mqtt_data
TSDB_USER=postgres
TSDB_PASS=your_tsdb_password_here

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Allowed CORS origins — comma-separated
# Add your Cloudflare Pages URL (e.g. https://snk-mes.pages.dev)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
